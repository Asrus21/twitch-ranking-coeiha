# Neon Postgres - injected automatically when you connect Neon via the Vercel
# Marketplace. You don't usually need to set this manually in production.
DATABASE_URL=

# Admin password for resetting the ranking (use a strong one)
ADMIN_PASSWORD=troque_essa_senha_forte

# Shared secret between the widget and the API (anti-spam)
# Pick any random string and put the same value in the widget JS
WIDGET_KEY=troque_essa_chave_aleatoria

# Twitch app credentials (https://dev.twitch.tv/console/apps)
# Create an app, copy Client ID and generate a Client Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
